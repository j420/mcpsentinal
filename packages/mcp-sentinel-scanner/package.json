{
  "name": "mcp-sentinel-scanner",
  "version": "0.2.0",
  "description": "MCP server for security scanning — analyze any MCP server against 177 detection rules with AST taint analysis, capability graph, and entropy-based secret detection",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "mcp-sentinel-scanner": "./dist/index.js"
  },
  "files": [
    "dist",
    "rules",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "bundle": "node bundle.mjs",
    "prepublishOnly": "npm run bundle",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "security",
    "scanner",
    "vulnerability",
    "prompt-injection",
    "owasp",
    "ai-security"
  ],
  "author": "MCP Sentinel",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/j420/mcpsentinal",
    "directory": "packages/mcp-sentinel-scanner"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "pino": "^9.0.0",
    "yaml": "^2.7.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@mcp-sentinel/analyzer": "workspace:*",
    "@mcp-sentinel/scorer": "workspace:*",
    "@mcp-sentinel/connector": "workspace:*",
    "@mcp-sentinel/database": "workspace:*",
    "esbuild": "^0.21.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
