{
  "name": "@mcp-sentinel/red-team",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "audit": "tsx src/cli.ts",
    "audit:json": "tsx src/cli.ts --json",
    "audit:html": "tsx src/cli.ts --html",
    "accuracy-dashboard": "tsx src/accuracy/cli.ts",
    "mutation:audit": "tsx src/mutation/cli.ts",
    "mutation:charter": "tsx src/mutation/charter-writer.ts",
    "cve-corpus": "tsx src/cve-corpus/cli.ts",
    "cve-corpus:report": "tsx src/cve-corpus/cli.ts --markdown",
    "cve-corpus:coverage": "tsx src/cve-corpus/cli.ts --generate-coverage-doc"
  },
  "dependencies": {
    "@mcp-sentinel/analyzer": "workspace:*",
    "@mcp-sentinel/database": "workspace:*",
    "pino": "^9.0.0",
    "typescript": "^5.5.0",
    "yaml": "^2.4.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "vitest": "^2.0.0",
    "tsx": "^4.19.0"
  }
}
