{
  "name": "mcp-sentinel",
  "version": "0.1.0",
  "private": true,
  "description": "The world's most comprehensive MCP security intelligence registry",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "db:migrate": "pnpm --filter=@mcp-sentinel/database run migrate",
    "db:seed": "pnpm --filter=@mcp-sentinel/database run seed",
    "db:reset": "pnpm --filter=@mcp-sentinel/database run reset",
    "crawl": "pnpm --filter=@mcp-sentinel/crawler run crawl",
    "scan": "pnpm --filter=@mcp-sentinel/scanner run scan",
    "enumerate": "pnpm --filter=@mcp-sentinel/scanner run enumerate",
    "score": "pnpm --filter=@mcp-sentinel/scorer run score",
    "risk-matrix": "pnpm --filter=@mcp-sentinel/risk-matrix run risk-matrix",
    "attack-graph": "pnpm --filter=@mcp-sentinel/attack-graph run attack-graph",
    "red-team": "pnpm --filter=@mcp-sentinel/red-team run audit",
    "dynamic-test": "pnpm --filter=@mcp-sentinel/scanner run scan -- --dynamic",
    "cli": "pnpm --filter=@mcp-sentinel/cli run cli",
    "compliance-scan": "pnpm --filter=@mcp-sentinel/compliance-agents run compliance-scan",
    "validate:evidence": "tsx tools/scripts/validate-evidence-chains.ts",
    "rule:census": "pnpm --filter=@mcp-sentinel/analyzer exec tsx ../../tools/scripts/rule-census.ts",
    "rule:baseline": "pnpm --filter=@mcp-sentinel/analyzer exec tsx ../../tools/scripts/rule-baseline-update.ts"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "turbo": "^2.3.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.29.3",
  "pnpm": {
    "onlyBuiltDependencies": [
      "tree-sitter",
      "tree-sitter-python"
    ]
  }
}
