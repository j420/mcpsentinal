# Database
DATABASE_URL=postgresql://sentinel:sentinel_dev@localhost:5432/mcp_sentinel

# GitHub token for crawler (optional but recommended for higher rate limits)
GITHUB_TOKEN=ghp_your_token_here

# Smithery API key (required for Smithery crawler)
SMITHERY_API_KEY=your_smithery_api_key_here

# API server
PORT=3100

# Web
API_URL=http://localhost:3100
NEXT_PUBLIC_API_URL=http://localhost:3100

# Anthropic API key (required for compliance-agents live LLM mode — ADR-009)
# Compliance scans default to mock mode; set this only when running
# `pnpm compliance-scan ... --live`. The rest of MCP Sentinel remains
# deterministic per ADR-006 and does NOT use this key.
ANTHROPIC_API_KEY=sk-ant-your_key_here
